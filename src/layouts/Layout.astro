---
interface Props {
  title: string;
}

const { title } = Astro.props;

import { basics } from "@cv";
const { summary, name } = basics;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} &bull; {name}</title>
    <meta name="description" content={summary} />
    <meta name="keywords" content="desarrollador fullstack, portfolio, andres muñoz, web development, world of warcraft, 3.3.5a, addons, raid dominion tools, frontend, backend" />
    <meta name="author" content={name} />
    <meta name="theme-color" content="#0f192b" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://iamjaguer.netlify.app/" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://iamjaguer.netlify.app/" />
    <meta property="og:title" content={`${title} • ${name}`} />
    <meta property="og:description" content={summary} />
    <meta property="og:image" content="https://iamjaguer.netlify.app/logo.png" />
    <meta property="og:image:alt" content={`Logo de ${name}`} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content={`${title} • ${name}`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://iamjaguer.netlify.app/" />
    <meta name="twitter:title" content={`${title} • ${name}`} />
    <meta name="twitter:description" content={summary} />
    <meta name="twitter:image" content="https://iamjaguer.netlify.app/logo.png" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="stylesheet" href="/styles/global.css" />
    <meta name="generator" content={Astro.generator} />

    <!-- Structured Data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": name,
      "url": "https://iamjaguer.netlify.app/",
      "image": "https://iamjaguer.netlify.app/logo.png",
      "jobTitle": "Desarrollador Fullstack",
      "description": summary,
      "sameAs": basics.profiles.map(p => p.url)
    })} />
  </head>
  <body>
    <slot />
    <div id="section-navigation" class="fixed bottom-8 right-8 z-[100] flex flex-col gap-3 no-print opacity-0 translate-y-4 pointer-events-none transition-all duration-700">
      <button
        id="scroll-up"
        class="p-4 bg-cyan-600/40 hover:bg-cyan-600 text-white border border-white/20 rounded-2xl backdrop-blur-xl shadow-[0_0_30px_rgba(6,182,212,0.4)] group transition-all duration-300 hover:scale-110 active:scale-90 hover:shadow-cyan-500/60"
        aria-label="Subir sección"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6 group-hover:-translate-y-1 transition-transform duration-300"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
        </svg>
      </button>
      <button
        id="scroll-down"
        class="p-4 bg-cyan-600/40 hover:bg-cyan-600 text-white border border-white/20 rounded-2xl backdrop-blur-xl shadow-[0_0_30px_rgba(6,182,212,0.4)] group transition-all duration-300 hover:scale-110 active:scale-90 hover:shadow-cyan-500/60"
        aria-label="Bajar sección"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6 group-hover:translate-y-1 transition-transform duration-300"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </button>
    </div>
    <script src="/scripts/global.js" is:inline></script>
  </body>
</html>
