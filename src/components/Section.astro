---
const { title, id } = Astro.props;
---

<section class="section w-full max-w-[800px] mx-auto min-h-screen pt-[6rem] pb-20" id={id}>
  {title && (
    <div class="mb-12 mt-4 flex flex-col items-center">
      <h2 class="text-3xl sm:text-4xl font-black text-white tracking-tighter uppercase">
        {title}
      </h2>
      <div class="w-12 h-1 bg-cyan-600 mt-2 rounded-full shadow-[0_0_10px_rgba(6,182,212,0.5)]"></div>
    </div>
  )}
  <div class="px-8">
    <slot />
  </div>
</section>