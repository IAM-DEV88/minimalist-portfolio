---
import { basics } from "@cv";
import Section from "@/components/Section.astro";
import Mail from "@/icons/Mail.astro";
import Phone from "@/icons/Phone.astro";
import GitHub from "@/icons/GitHub.astro";
import LinkedIn from "@/icons/LinkedIn.astro";
import WorldMap from "@/icons/WorldMap.astro";
import Twitch from "@/icons/Twitch.astro";
import Youtube from "@/icons/Youtube.astro";
import TikTok from "@/icons/TikTok.astro";
import Facebook from "@/icons/Facebook.astro";

const { name, label, image, location, profiles, phone, email } = basics;
const { city, region, countryCode } = location;

const SOCIAL_ICONS: Record<string, any> = {
  GitHub,
  LinkedIn,
  Twitch,
  Youtube,
  TikTok,
  Facebook,
};

const linkedInfo = profiles.find(({network})=>network==="LinkedIn")
const linkedUrl = linkedInfo?.url
---

<Section id="section1">
  <div id="hero-content" class="flex flex-col items-center pb-12 opacity-0 translate-y-8 transition-all duration-1000 ease-out print:opacity-100 print:transform-none">
    <div class="relative group print:hidden">
      <!-- Glow effect matching the logo -->
      <div class="absolute -inset-4 bg-gradient-to-r from-cyan-600 to-blue-600 rounded-full blur-2xl opacity-20 group-hover:opacity-40 transition duration-1000 group-hover:duration-200 no-print"></div>
      
      <!-- Circuit pattern background sutil -->
      <div class="absolute inset-0 bg-[url('/circuit.svg')] opacity-10 group-hover:opacity-20 transition-opacity no-print"></div>

      <figure class="relative">
        <img 
          id="hero-mascot"
          src={image} 
          alt={name} 
          class="w-48 h-48 sm:w-64 sm:h-64 object-contain drop-shadow-[0_0_30px_rgba(6,182,212,0.3)] group-hover:drop-shadow-[0_0_50px_rgba(6,182,212,0.5)] transition-all duration-700 cursor-pointer" 
        />
      </figure>
    </div>
    
    <div class="flex flex-col items-center gap-y-6 text-center mt-2">
      <div class="space-y-2">
        <h1 class="text-[1.8rem] sm:text-[2rem] font-black tracking-tighter text-white bg-clip-text text-transparent bg-gradient-to-b from-white to-gray-500 print:text-black print:bg-none print:text-4xl">
          {name}
        </h1>
        <p class="text-cyan-400 font-black text-[.5rem] sm:text-[.85rem] uppercase tracking-[0.4em] drop-shadow-[0_0_10px_rgba(6,182,212,0.5)] print:text-gray-700 print:drop-shadow-none">
          {label}
        </p>
      </div>

      <div class="flex items-center gap-3 text-[10px] sm:text-xs font-black text-gray-400 uppercase tracking-[0.3em] bg-white/5 py-2 px-6 rounded-2xl border border-white/10 backdrop-blur-md print:bg-none print:border-none print:text-gray-600">
        <span class="no-print"><WorldMap /></span>
        <span>{city}, {region}</span>
        <span class="text-amber-500">•</span>
        <span>{countryCode}</span>
      </div>

      <!-- Versión de impresión: Información de contacto en texto -->
      <div class="hidden print:block w-full mt-4">
        <div class="flex flex-col gap-2 text-sm text-gray-800 font-medium">
          {email && (
            <p class="flex justify-center items-center gap-2">
              <span class="font-black uppercase tracking-widest text-[9px] text-gray-500">Email:</span> {email}
            </p>
          )}
          {phone && (
            <p class="flex justify-center items-center gap-2">
              <span class="font-black uppercase tracking-widest text-[9px] text-gray-500">Teléfono:</span> {phone}
            </p>
          )}
          {profiles.map(({ network, url }) => (
            <p class="flex justify-center items-center gap-2">
              <span class="font-black uppercase tracking-widest text-[9px] text-gray-500">{network}:</span> {url}
            </p>
          ))}
        </div>
      </div>

      <footer class="flex flex-row flex-wrap justify-center gap-6 mt-6 no-print">
        {
          email && (
            <a
              class="group relative p-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-[1.5rem] transition-all duration-300 hover:-translate-y-2 shadow-xl hover:shadow-cyan-500/20"
              href={`mailto:${email}`}
              title={`Enviar correo electronico a ${name}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Mail />
              <span class="absolute -top-14 left-1/2 -translate-x-1/2 scale-0 group-hover:scale-100 transition-all duration-200 bg-slate-900/95 backdrop-blur-md text-white text-[11px] font-bold py-2 px-4 rounded-xl border border-white/20 shadow-2xl z-50 pointer-events-none whitespace-nowrap">
                Email
              </span>
            </a>
          )
        }
        {
          phone && (
            <a
              class="group relative p-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-[1.5rem] transition-all duration-300 hover:-translate-y-2 shadow-xl hover:shadow-cyan-500/20"
              href={`tel:${phone}`}
              title={`Llamar a ${name}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Phone />
              <span class="absolute -top-14 left-1/2 -translate-x-1/2 scale-0 group-hover:scale-100 transition-all duration-200 bg-slate-900/95 backdrop-blur-md text-white text-[11px] font-bold py-2 px-4 rounded-xl border border-white/20 shadow-2xl z-50 pointer-events-none whitespace-nowrap">
                Teléfono
              </span>
            </a>
          )
        }
        {
          profiles
            .filter(({ network }) => SOCIAL_ICONS[network])
            .map(({ network, url }) => {
              const Icon = SOCIAL_ICONS[network];
              return (
                <a
                  class="group relative p-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-[1.5rem] transition-all duration-300 hover:-translate-y-2 shadow-xl hover:shadow-cyan-500/20"
                  href={`${url}`}
                  title={`Perfil de ${network}`}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon />
                  <span class="absolute -top-14 left-1/2 -translate-x-1/2 scale-0 group-hover:scale-100 transition-all duration-200 bg-slate-900/95 backdrop-blur-md text-white text-[11px] font-bold py-2 px-4 rounded-xl border border-white/20 shadow-2xl z-50 pointer-events-none whitespace-nowrap">
                    {network}
                  </span>
                </a>
              );
            })
        }
      </footer>
    </div>
  </div>
</Section>

<style>
  footer a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
  }
</style>
