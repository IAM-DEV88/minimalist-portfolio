<footer class="w-full max-w-[800px] mx-auto pt-20 pb-12 px-6 no-print">
  <div class="flex flex-col items-center gap-6 border-t border-white/5 pt-12">
    <div class="flex flex-col items-center leading-none">
      <span class="text-2xl font-black tracking-tighter text-white">IAM</span>
      <span class="text-[10px] uppercase font-bold tracking-[0.4em] text-cyan-500">Jaguer</span>
    </div>
    
    <p class="text-[10px] font-bold uppercase tracking-widest text-gray-500 text-center">
      &copy; {new Date().getFullYear()}</span>
    </p>
    
    <div class="flex gap-4 opacity-30 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-500">
      <div class="w-1 h-1 bg-white rounded-full"></div>
      <div class="w-1 h-1 bg-white rounded-full"></div>
      <div class="w-1 h-1 bg-white rounded-full"></div>
    </div>
  </div>
</footer>