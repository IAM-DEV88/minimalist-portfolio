---
import Section from "../Section.astro";
import { work } from "@cv";
---

<Section title="Experiencia" id="section3" i18n="section.experience">
  <div id="experience-list" class="flex flex-col gap-4 w-full">
    {work.map(({ name, position, startDate, endDate, highlights }) => {
      const start = new Date(startDate);
      const end = endDate ? new Date(endDate) : new Date();
      const monthsDiff = (end.getFullYear() - start.getFullYear()) * 12 + (end.getMonth() - start.getMonth());
      const years = Math.floor(monthsDiff / 12);
      const months = monthsDiff % 12;
      let durationString = "";
      if (years > 0) durationString += years === 1 ? "1 año" : `${years} años`;
      if (months > 0) {
        durationString += durationString ? " y " : "";
        durationString += months === 1 ? "1 mes" : `${months} meses`;
      }
      const cardId = `exp-${name.toLowerCase().replace(/[^a-z]/g, '-').replace(/-+/g, '-')}`;
      return (
        <article id={cardId} class="exp-card group relative bg-slate-800/60 border border-slate-700/80 rounded-2xl p-5 hover:-translate-y-0.5 hover:border-cyan-500 transition-all duration-300 flex flex-col gap-3">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1">
              <h3 class="text-base font-bold text-white group-hover:text-white transition-colors">{name}</h3>
              <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mt-0.5">{position}</p>
            </div>
            <div class="flex flex-col items-end shrink-0">
              <span class="exp-duration text-[11px] font-bold text-cyan-400 whitespace-nowrap">{durationString}</span>
              <span class="text-[10px] text-slate-500 font-medium whitespace-nowrap">{startDate} — <span class="exp-end">{endDate || "Actual"}</span></span>
            </div>
          </div>

          <ul class="flex flex-col gap-2 mt-1">
            {highlights.map((h) => (
              <li class="flex gap-2.5 text-sm text-slate-300 leading-relaxed">
                <span class="text-cyan-500/60 mt-1.5 shrink-0">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </span>
                <span>{h}</span>
              </li>
            ))}
          </ul>
        </article>
      )
    })}
  </div>
</Section>
