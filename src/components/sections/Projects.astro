---
import { projects } from "@cv";
import Section from "../Section.astro";

const highlightCounts = projects.reduce((acc: Record<string, number>, project) => {
  project.highlights.forEach((highlight) => {
    acc[highlight] = (acc[highlight] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

const initialProjects = projects.slice(0, 6);
---

<Section title="Proyectos" id="section2">
<div id="project-list" class="flex flex-col w-full gap-8">
  <!-- Cabecera de Controles: Todo en una sola línea -->
  <div class="flex flex-col md:flex-row items-center gap-4 w-full no-print mb-8">
    <!-- Búsqueda -->
    <div class="relative flex-1 w-full">
      <input
        id="search-input"
        list="projectNames"
        placeholder="Buscar..."
        class="w-full bg-white/5 border border-white/10 text-white text-sm rounded-xl px-5 py-2.5 focus:outline-none focus:border-cyan-500 transition-all placeholder:text-gray-500 font-medium backdrop-blur-sm"
      />
      <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-500">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      </div>
    </div>

    <!-- Filtro Desplegable -->
    <div class="relative w-full md:w-auto">
      <button 
        id="filter-toggle"
        class="flex items-center justify-between w-full md:w-auto min-w-[160px] bg-white/[0.03] border border-white/10 rounded-xl px-4 py-2.5 text-[11px] font-black uppercase tracking-[0.1em] text-gray-400 hover:text-cyan-400 hover:border-cyan-500/50 transition-all group"
      >
        <div class="flex items-center gap-2">
          <svg class="w-3.5 h-3.4 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
          <span>Stack</span>
        </div>
        <svg class="w-3.5 h-3.5 transition-transform duration-300 group-[.active]:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>

      <div 
        id="filter-dropdown" 
        class="absolute top-full right-0 mt-2 w-full md:w-max min-w-[200px] bg-slate-900/95 border border-white/10 rounded-xl p-3 backdrop-blur-xl shadow-2xl opacity-0 scale-95 pointer-events-none transition-all duration-300 z-40 origin-top-right"
      >
        <div class="grid grid-cols-1 gap-y-1">
          {
            Object.entries(highlightCounts).map(([highlight, count]) => (
              <label class="group flex items-center justify-between gap-4 cursor-pointer select-none p-1.5 hover:bg-white/5 rounded-lg transition-colors">
                <div class="flex items-center gap-2.5">
                  <div class="relative w-3.5 h-3.5 bg-white/5 border border-white/10 rounded group-hover:border-cyan-500 transition-all overflow-hidden">
                    <input type="checkbox" value={highlight} class="filter-checkbox absolute inset-0 opacity-0 cursor-pointer z-10" />
                    <div class="check-mark hidden absolute inset-0 bg-gradient-to-br from-cyan-500 to-blue-600 pointer-events-none">
                      <svg class="w-full h-full text-white p-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M5 13l4 4L19 7"/></svg>
                    </div>
                  </div>
                  <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400 group-hover:text-white transition-colors">
                    {highlight}
                  </span>
                </div>
                <span class="text-cyan-500/50 font-black text-[9px] bg-cyan-500/5 px-1.5 py-0.5 rounded border border-cyan-500/10">
                  {count}
                </span>
              </label>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Paginación -->
    <div id="pagination-controls" class="flex items-center gap-3 shrink-0 bg-white/[0.03] border border-white/10 rounded-xl px-3 py-1.5">
      <button id="prev-page" class="p-2 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all disabled:opacity-10 disabled:cursor-not-allowed" aria-label="Anterior">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <span id="page-info" class="text-[9px] font-black uppercase tracking-[0.1em] text-cyan-400/60 min-w-[40px] text-center"></span>
      <button id="next-page" class="p-2 text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all disabled:opacity-10 disabled:cursor-not-allowed" aria-label="Siguiente">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </button>
    </div>
  </div>

  <datalist id="projectNames">
    {projects.map((project) => <option value={project.name} />)}
  </datalist>

  <!-- Lista de proyectos con Rejilla Dinámica -->
  <ul
    id="project-list-items"
    class="grid grid-cols-1 md:grid-cols-6 gap-4 w-full no-print min-h-[400px]"
  >
    {initialProjects.map((project, index) => {
      let gridClass = "md:col-span-3";
      if (index === 0) gridClass = "md:col-span-4";
      if (index === 1) gridClass = "md:col-span-2";

      return (
        <li 
          class={`group relative bg-white/[0.03] border border-white/5 rounded-2xl p-5 hover:bg-white/10 hover:border-cyan-500/50 transition-all duration-500 cursor-pointer overflow-hidden flex flex-col ${gridClass}`} 
          data-project-name={project.name}
        >
          <div class="absolute -inset-1 bg-gradient-to-r from-cyan-600/10 to-blue-600/10 rounded-2xl blur opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
          
          <div class="relative flex flex-col h-full pointer-events-none">
            <h3 class="text-lg font-black text-white group-hover:text-cyan-400 transition-colors mb-1.5 tracking-tight">
              {project.name}
            </h3>
            <p class="text-[13px] text-gray-400 line-clamp-2 mb-4 leading-relaxed font-medium">
              {project.description}
            </p>
            <div class="mt-auto flex flex-wrap gap-1.5">
              {project.highlights.map(h => (
                <span class="text-[9px] font-bold uppercase tracking-wider text-gray-400 px-2 py-0.5 bg-white/5 rounded-md border border-white/5 group-hover:border-cyan-500/20 transition-colors">
                  {h}
                </span>
              ))}
            </div>
          </div>
        </li>
      )
    })}
  </ul>

  <!-- Versión de impresión: Todos los proyectos sin paginación -->
  <ul class="hidden print:block space-y-8 w-full">
    {projects.map((project) => (
      <li class="border-b border-gray-200 pb-6 last:border-0">
        <h3 class="text-lg font-bold text-black mb-2">{project.name}</h3>
        <p class="text-sm text-gray-700 mb-4 leading-relaxed">{project.description}</p>
        <div class="flex flex-wrap gap-2">
          {project.highlights.map(h => (
            <span class="text-[9pt] font-medium text-gray-600 px-2 py-0.5 bg-gray-100 rounded border border-gray-200">
              {h}
            </span>
          ))}
        </div>
        {project.url && (
          <p class="text-[9pt] text-gray-500 mt-2">
            URL: <span class="underline">{project.url}</span>
          </p>
        )}
      </li>
    ))}
  </ul>
</Section>

<style>
  .filter-checkbox:checked ~ .check-mark {
    display: block;
  }
  
  #project-list-items {
    transition: all 0.5s ease;
  }

  .project-fade-in {
    animation: projectFadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes projectFadeIn {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>

<script define:vars={{ projects }} is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    let searchQuery = "";
    let selectedFilters = [];
    let currentPage = 1;
    const itemsPerPage = 6;
  
    const searchInput = document.getElementById("search-input");
    const filterCheckboxes = document.querySelectorAll(".filter-checkbox");
    const projectListItems = document.getElementById("project-list-items");
    const prevPageButton = document.getElementById("prev-page");
    const nextPageButton = document.getElementById("next-page");
    const pageInfo = document.getElementById("page-info");
    const filterToggle = document.getElementById("filter-toggle");
    const filterDropdown = document.getElementById("filter-dropdown");

    // Lógica del Desplegable de Filtros
    filterToggle?.addEventListener("click", (e) => {
      e.stopPropagation();
      const isActive = filterToggle.classList.toggle("active");
      if (isActive) {
        filterDropdown?.classList.remove("opacity-0", "scale-95", "pointer-events-none");
        filterDropdown?.classList.add("opacity-100", "scale-100", "pointer-events-auto");
      } else {
        filterDropdown?.classList.add("opacity-0", "scale-95", "pointer-events-none");
        filterDropdown?.classList.remove("opacity-100", "scale-100", "pointer-events-auto");
      }
    });

    // Cerrar desplegable al hacer clic fuera
    document.addEventListener("click", (e) => {
      if (!filterToggle?.contains(e.target) && !filterDropdown?.contains(e.target)) {
        filterToggle?.classList.remove("active");
        filterDropdown?.classList.add("opacity-0", "scale-95", "pointer-events-none");
        filterDropdown?.classList.remove("opacity-100", "scale-100", "pointer-events-auto");
      }
    });
  
    function getFilteredProjects() {
      return projects.filter((project) => {
        const matchesSearch = project.name
          .toLowerCase()
          .includes(searchQuery.toLowerCase());
        const matchesFilters =
          selectedFilters.length === 0 ||
          selectedFilters.some((filter) => project.highlights.includes(filter));
        return matchesSearch && matchesFilters;
      });
    }
  
    function updateProjectList(isInitial = false) {
      const filteredProjects = getFilteredProjects();
      const totalPages = Math.ceil(filteredProjects.length / itemsPerPage) || 1;
  
      if (currentPage > totalPages) {
        currentPage = totalPages;
      }
  
      const startIndex = (currentPage - 1) * itemsPerPage;
      const endIndex = startIndex + itemsPerPage;
      const projectsToShow = filteredProjects.slice(startIndex, endIndex);
  
      const render = () => {
        projectListItems.innerHTML = projectsToShow
          .map((project, index) => {
            // Rejilla dinámica: el primero destaca un poco más si estamos en la pag 1 y no hay filtros
            let gridClass = "md:col-span-3";
            if (currentPage === 1 && searchQuery === "" && selectedFilters.length === 0) {
              if (index === 0) gridClass = "md:col-span-4";
              if (index === 1) gridClass = "md:col-span-2";
            }

            return `
            <li class="group relative bg-white/[0.03] border border-white/5 rounded-2xl p-5 hover:bg-white/10 hover:border-cyan-500/50 transition-all duration-500 cursor-pointer overflow-hidden flex flex-col project-fade-in ${gridClass}" data-project-name="${project.name}" style="animation-delay: ${index * 0.05}s">
              <div class="absolute -inset-1 bg-gradient-to-r from-cyan-600/10 to-blue-600/10 rounded-2xl blur opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
              <div class="relative flex flex-col h-full pointer-events-none">
                <h3 class="text-lg font-black text-white group-hover:text-cyan-400 transition-colors mb-1.5 tracking-tight">${project.name}</h3>
                <p class="text-[13px] text-gray-400 line-clamp-2 mb-4 leading-relaxed font-medium">
                  ${project.description}
                </p>
                <div class="mt-auto flex flex-wrap gap-1.5">
                  ${project.highlights.map(h => `
                    <span class="text-[9px] font-bold uppercase tracking-wider text-gray-400 px-2 py-0.5 bg-white/5 rounded-md border border-white/5 group-hover:border-cyan-500/20 transition-colors">
                      ${h}
                    </span>
                  `).join('')}
                </div>
              </div>
            </li>`;
          })
          .join("");

        projectListItems.style.opacity = "1";

        projectListItems.querySelectorAll("li").forEach((li) => {
          li.addEventListener("click", () => {
            window.dispatchEvent(new CustomEvent('open-project-modal', { 
              detail: { projectName: li.dataset.projectName } 
            }));
          });
        });
      };

      if (isInitial) {
        render();
      } else {
        projectListItems.style.opacity = "0";
        setTimeout(render, 200);
      }
  
      pageInfo.textContent = `${currentPage} / ${totalPages}`;
      prevPageButton.disabled = currentPage === 1;
      nextPageButton.disabled = currentPage === totalPages;
    }
  
    function handleSearchChange() {
      searchQuery = searchInput.value;
      currentPage = 1;
      updateProjectList();
    }
  
    function handleFilterChange(event) {
      const filter = event.target.value;
      if (event.target.checked) {
        selectedFilters.push(filter);
      } else {
        selectedFilters = selectedFilters.filter((f) => f !== filter);
      }
      currentPage = 1;
      updateProjectList();
    }
  
    function handlePrevPage() {
      if (currentPage > 1) {
        currentPage--;
        updateProjectList();
      }
    }
  
    function handleNextPage() {
      const filteredProjects = getFilteredProjects();
      const totalPages = Math.ceil(filteredProjects.length / itemsPerPage);
      if (currentPage < totalPages) {
        currentPage++;
        updateProjectList();
      }
    }
  
    searchInput.addEventListener("input", handleSearchChange);
    filterCheckboxes.forEach((checkbox) => {
      checkbox.addEventListener("change", handleFilterChange);
    });
    prevPageButton.addEventListener("click", handlePrevPage);
    nextPageButton.addEventListener("click", handleNextPage);
  
    updateProjectList(true);
  });
</script>