---
import Section from "../Section.astro";
import { basics, projects } from "@cv";
const { summary } = basics;
const tags = Array.from(new Set(projects.flatMap((p) => p.highlights)));
---

<Section title="Acerca de mi" id="section4">
  <div class="space-y-12">
    <p class="text-lg text-gray-300 leading-relaxed font-medium">
      {summary}
    </p>

    <div class="space-y-6">
      <h3 class="text-xs font-black uppercase tracking-[0.3em] text-cyan-400 text-center">
        Tecnologías & Herramientas
      </h3>
      
      <ul class="flex flex-wrap justify-center gap-4">
        {tags.map((tag) => (
          <li class="group relative px-6 py-2 bg-white/5 border border-white/10 rounded-2xl hover:bg-white/10 hover:border-cyan-500 transition-all duration-300 hover:-translate-y-1">
            <span class="text-xs font-black text-gray-300 group-hover:text-white transition-colors uppercase tracking-[0.1em]">{tag}</span>
            <div class="absolute -inset-0.5 bg-gradient-to-r from-cyan-600 to-blue-600 rounded-2xl blur opacity-0 group-hover:opacity-20 transition-opacity"></div>
          </li>
        ))}
      </ul>
    </div>

    <!-- Banner para la animación de lluvia de palabras -->
    <div class="word-rain-banner mask-fade-y border-t border-b border-white/5 py-8">
      {tags.map((tag) => <span class="falling-word text-cyan-400 font-black uppercase tracking-[0.2em] pointer-events-none drop-shadow-[0_0_10px_rgba(6,182,212,0.4)]">{tag}</span>)}
    </div>
  </div>
</Section>

<style>
  .word-rain-banner {
    position: relative;
    width: 100%;
    height: 120px;
    overflow: hidden;
  }

  .mask-fade-y {
    mask-image: linear-gradient(to bottom, transparent, black 20%, black 80%, transparent);
  }

  .falling-word {
    position: absolute;
    font-size: 0.85rem;
    animation: fall 15s linear infinite;
    opacity: 0;
    white-space: nowrap;
    filter: drop-shadow(0 0 8px rgba(168, 85, 247, 0.6));
  }

  @keyframes fall {
    0% {
      transform: translateY(-50px) scale(0.8);
      opacity: 0;
    }
    20% {
      opacity: 0.6;
      transform: translateY(20px) scale(1.1);
    }
    80% {
      opacity: 0.6;
      transform: translateY(100px) scale(1.1);
    }
    100% {
      transform: translateY(180px) scale(0.8);
      opacity: 0;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const words = document.querySelectorAll(".falling-word");

    words.forEach((word) => {
      const htmlWord = word as HTMLElement;
      const delay = Math.random() * 15;
      const leftPosition = Math.random() * 90 + 5;
      const size = 0.7 + Math.random() * 0.6;
      const colors = ['#06b6d4', '#3b82f6', '#f59e0b', '#ffffff'];
      const randomColor = colors[Math.floor(Math.random() * colors.length)];

      htmlWord.style.animationDelay = `${delay}s`;
      htmlWord.style.left = `${leftPosition}%`;
      htmlWord.style.fontSize = `${size}rem`;
      htmlWord.style.color = randomColor;
    });
  });
</script>
